rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if false;
      allow write: if request.auth != null 
                   && firestore.get(/databases/(default)/documents/user_roles/$(request.auth.uid)).data.role == 'admin'
                   && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
