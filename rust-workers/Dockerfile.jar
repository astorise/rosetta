FROM rust:1.94-slim-bookworm AS builder
WORKDIR /app
COPY . .
RUN cargo build --release --bin worker-jar

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates default-jre-headless curl && rm -rf /var/lib/apt/lists/*
RUN curl -L https://github.com/leibnitz27/cfr/releases/download/0.152/cfr-0.152.jar -o /opt/cfr.jar
COPY --from=builder /app/target/release/worker-jar /worker-jar
ENV RUST_LOG=info
EXPOSE 8080
CMD ["/worker-jar"]
