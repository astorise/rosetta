rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/user_roles/$(request.auth.uid)).data.role == 'admin';
    }

    function isRawDocsBucket() {
      return bucket == 'raw-docs-bucket'
        || bucket.matches('^[a-z0-9.-]+-raw-docs$');
    }

    function isMarkdownBucket() {
      return bucket == 'rag-markdown-bucket'
        || bucket.matches('^[a-z0-9.-]+-rag-markdown$');
    }

    match /{allPaths=**} {
      allow read: if isMarkdownBucket() && isSignedIn();
      allow write: if isRawDocsBucket()
                   && isAdmin()
                   && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
